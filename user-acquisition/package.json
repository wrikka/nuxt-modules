{
	"name": "@wrikka/user-acquisition",
	"type": "module",
	"version": "0.0.1",
	"main": "./dist/module.mjs",
	"exports": {
		".": {
			"import": "./dist/module.mjs",
			"require": "./dist/module.mjs"
		},
		"./runtime": {
			"import": "./src/runtime/index.ts",
			"types": "./src/runtime/index.ts"
		},
		"./runtime/*": {
			"import": "./src/runtime/*",
			"types": "./src/runtime/*"
		},
		"./runtime/types": {
			"import": "./src/runtime/types/index.ts",
			"types": "./src/runtime/types/index.ts"
		}
	},
	"scripts": {
		"dev": "nuxt dev",
		"build": "nuxt build-module",
		"preview": "nuxt preview",
		"format": "dprint fmt",
		"prepare": "nuxt prepare",
		"typecheck": "nuxt typecheck",
		"test": "vitest",
		"lint": "vue-tsc --noEmit && oxlint",
		"verify": "bun run lint && bun run test && bun run build"
	},
	"dependencies": {
		"@nuxt/kit": "^4.3.1",
		"nanoid": "^5.1.6",
		"nuxt": "^4.3.1",
		"vue": "^3.5.28",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@nuxt/module-builder": "^1.0.2",
		"@types/node": "^25.3.0",
		"@unocss/nuxt": "^66.6.0",
		"@vue/test-utils": "^2.4.6",
		"dprint": "^0.51.1",
		"jsdom": "^25.0.1",
		"oxlint": "^1.49.0",
		"unocss": "^66.6.0",
		"vitest": "^4.0.18",
		"vue-tsc": "^3.2.4"
	}
}
