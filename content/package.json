{
	"name": "@wrikka/content",
	"type": "module",
	"version": "0.0.1",
	"main": "./dist/module.mjs",
	"exports": {
		".": {
			"import": "./dist/module.mjs",
			"require": "./dist/module.mjs"
		},
		"./runtime": {
			"import": "./src/runtime/index.ts",
			"types": "./src/runtime/index.ts"
		},
		"./runtime/*": {
			"import": "./src/runtime/*",
			"types": "./src/runtime/*"
		},
		"./runtime/shared/types": {
			"import": "./src/runtime/shared/types/index.ts",
			"types": "./src/runtime/shared/types/index.ts"
		}
	},
	"scripts": {
		"dev": "nuxt dev",
		"build": "nuxt build-module",
		"preview": "nuxt preview",
		"format": "dprint fmt",
		"lint": "tsc --noEmit && oxlint --fix",
		"typecheck": "nuxt typecheck",
		"test": "vitest",
		"examples": "bun run --cwd examples/basic dev",
		"verify": "bun run lint && bun run test && bun run build"
	},
	"dependencies": {
		"@nuxt/icon": "^2.2.1",
		"@nuxt/image": "^2.0.0",
		"@nuxt/kit": "^4.3.1",
		"@nuxtjs/feed": "^2.0.0",
		"@nuxtjs/robots": "^5.7.0",
		"@nuxtjs/seo": "^3.4.0",
		"@nuxtjs/sitemap": "^7.6.0",
		"@vueuse/core": "^14.2.1",
		"@vueuse/nuxt": "^14.2.1",
		"defu": "^6.1.4",
		"dompurify": "^3.3.1",
		"fuse.js": "^7.1.0",
		"glob": "^13.0.6",
		"gray-matter": "^4.0.3",
		"h3": "^1.15.5",
		"marked": "^17.0.3",
		"nuxt": "^4.3.1",
		"shiki": "^3.22.0",
		"vite": "^7.3.1",
		"vue": "^3.5.28",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@nuxt/kit": "^4.3.1",
		"@nuxt/module-builder": "^1.0.2",
		"@nuxt/schema": "^4.3.1",
		"@nuxtjs/color-mode": "^4.0.0",
		"@pinia/nuxt": "^0.11.3",
		"@scalar/nuxt": "^0.5.81",
		"@types/node": "^25.3.0",
		"@unocss/nuxt": "^66.6.0",
		"@vue-macros/nuxt": "^3.1.2",
		"dprint": "^0.51.1",
		"nuxt-mcp-dev": "0.3.2",
		"oxlint": "^1.49.0",
		"vite-plugin-checker": "^0.12.0",
		"vitest": "^4.0.18",
		"vue-tsc": "^3.2.4"
	}
}
