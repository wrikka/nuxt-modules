{
  "name": "@wrikka/wimage-editor",
  "version": "0.1.0",
  "description": "Image editor module for Nuxt.js with canvas-based editing capabilities",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.ts",
      "import": "./dist/module.mjs",
      "require": "./dist/module.cjs"
    }
  },
  "main": "./dist/module.cjs",
  "types": "./dist/types.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt-build-module",
    "lint": "nuxt typecheck",
    "release": "release-it",
    "test": "vitest",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@nuxt/kit": "^3.14.0"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^0.8.4",
    "@nuxt/schema": "^3.14.0",
    "@types/node": "^20.17.6",
    "@unocss/nuxt": "^66.0.0",
    "nuxt": "^3.14.0",
    "typescript": "~5.6.3",
    "unocss": "^66.0.0",
    "vitest": "^2.1.5",
    "vue-tsc": "^2.1.10"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@latest"
  }
}
