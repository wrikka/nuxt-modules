{
  "name": "@wrikka/wnotifications",
  "type": "module",
  "version": "0.0.1",
  "main": "./dist/module.mjs",
  "exports": {
    ".": {
      "import": "./dist/module.mjs",
      "require": "./dist/module.mjs"
    },
    "./runtime": {
      "import": "./src/runtime/index.ts",
      "types": "./src/runtime/index.ts"
    },
    "./runtime/*": {
      "import": "./src/runtime/*",
      "types": "./src/runtime/*"
    },
    "./runtime/types": {
      "import": "./src/runtime/types/index.ts",
      "types": "./src/runtime/types/index.ts"
    }
  },
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt-build-module",
    "preview": "nuxt preview",
    "format": "dprint fmt",
    "prepare": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "test": "vitest",
    "lint": "nuxt typecheck && oxlint --type-aware --fix",
    "verify": "bun run lint && bun run test && bun run build",
    "release": "release-it"
  },
  "dependencies": {
    "@nuxt/kit": "^4.3.1",
    "h3": "^2.0.1-rc.14",
    "nuxt": "^4.3.1",
    "vue": "^3.5.29",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^1.0.2",
    "@types/node": "^25.3.2",
    "@vue/test-utils": "^2.4.6",
    "dprint": "^0.51.1",
    "jsdom": "^25.0.1",
    "oxlint": "^1.50.0",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  }
}
