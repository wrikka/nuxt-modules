{
  "name": "@wrikka/wdocs",
  "version": "0.1.0",
  "description": "Documentation module like VitePress for Nuxt",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "runtime"
  ],
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt-build-module",
    "lint": "nuxt typecheck",
    "release": "release-it",
    "test": "vitest",
    "postinstall": "nuxt prepare"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@latest"
  },
  "dependencies": {
    "@nuxt/kit": "^4.3.1",
    "@nuxtjs/color-mode": "^3.5.2",
    "@vueuse/core": "^14.2.1",
    "@vueuse/head": "^2.0.0",
    "@wrikka/wcontent": "workspace:*",
    "@wrikka/wmarkdown": "workspace:*",
    "defu": "^6.1.4",
    "feed": "^4.2.2",
    "minisearch": "^7.1.2",
    "shiki": "^3.0.0",
    "@shikijs/transformers": "^3.0.0",
    "zod": "^3.24.0",
    "simple-git": "^3.27.0",
    "twoslash-vue": "^0.0.1",
    "@vue/tsconfig": "^0.7.0"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.0",
    "@iconify-json/mdi": "^1.2.0",
    "@types/node": "^25.3.3",
    "@unocss/nuxt": "^66.6.4",
    "@vite-pwa/nuxt": "^0.10.0",
    "@vue-macros/nuxt": "^3.1.2",
    "@vueuse/nuxt": "^14.2.1",
    "nuxt": "^4.3.1",
    "typescript": "^5.9.3",
    "unocss": "^66.6.4",
    "vitest": "^4.0.18",
    "vue": "^3.5.29",
    "vue-tsc": "^3.2.5"
  }
