{
  "name": "@wrikka/wtheme",
  "version": "0.1.0",
  "description": "UnoCSS preset for Wrikka design system theme",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./preset": {
      "import": "./src/preset.ts",
      "types": "./src/preset.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "lint": "nuxt typecheck",
    "release": "release-it",
    "test": "vitest",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "unocss": "^65.5.0"
  },
  "devDependencies": {
    "@nuxt/devtools": "^2.0.0",
    "nuxt": "^3.15.0",
    "release-it": "^18.0.0",
    "typescript": "^5.7.0"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@latest"
  },
  "publishConfig": {
    "access": "public"
  }
}
