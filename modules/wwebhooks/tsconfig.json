{
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "#webhooks/*": [
        "./src/runtime/*"
      ],
      "#webhooks": [
        "./src/runtime"
      ],
      "#webhooks/types": [
        "./src/runtime/types"
      ]
    },
    "types": [
      "vitest/globals",
      "node"
    ]
  },
  "include": [
    "src/**/*",
    "test/**/*",
    ".nuxt/nuxt.d.ts",
    ".nuxt/imports.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
