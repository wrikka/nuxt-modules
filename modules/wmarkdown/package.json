{
  "name": "@wrikka/wmarkdown",
  "version": "0.1.0",
  "description": "Advanced Markdown module for Nuxt with custom parser and Notion-like editor",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "runtime"
  ],
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt-build-module",
    "lint": "nuxt typecheck",
    "release": "release-it",
    "test": "vitest",
    "postinstall": "nuxt prepare"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@latest"
  },
  "dependencies": {
    "@nuxt/kit": "^4.3.1",
    "shiki": "^3.0.0",
    "@shikijs/transformers": "^3.0.0",
    "@vueuse/core": "^14.2.1",
    "@vueuse/head": "^2.0.0",
    "zod": "^3.24.0",
    "defu": "^6.1.4",
    "mermaid": "^11.4.0",
    "katex": "^0.16.21"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.0",
    "@iconify-json/mdi": "^1.2.0",
    "@types/node": "^25.3.3",
    "@unocss/nuxt": "^66.6.4",
    "@vue-macros/nuxt": "^3.1.2",
    "@vueuse/nuxt": "^14.2.1",
    "nuxt": "^4.3.1",
    "typescript": "^5.9.3",
    "unocss": "^66.6.4",
    "vitest": "^4.0.18",
    "vue": "^3.5.29",
    "vue-tsc": "^3.2.5"
  }
}
