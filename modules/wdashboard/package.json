{
  "dependencies": {
    "@nuxt/kit": "^3.10.0"
  },
  "description": "Dashboard module with essential tabs for Nuxt",
  "devDependencies": {
    "@nuxt/module-builder": "^0.5.5",
    "@nuxt/schema": "^3.10.0",
    "@unocss/nuxt": "^66.6.4",
    "@wrikka/wui": "workspace:*",
    "nuxt": "^3.10.0",
    "typescript": "^5.3.0",
    "unocss": "^66.6.4",
    "vitest": "^1.2.0"
  },
  "exports": {
    ".": {
      "types": "./dist/types.d.ts",
      "import": "./dist/module.mjs",
      "require": "./dist/module.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "main": "./dist/module.cjs",
  "name": "@wrikka/wdashboard",
  "overrides": {
    "vite": "npm:rolldown-vite@latest"
  },
  "peerDependencies": {
    "@wrikka/wui": "workspace:*"
  },
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt-build-module --entry ./module.ts",
    "lint": "nuxt typecheck",
    "release": "release-it",
    "test": "vitest",
    "postinstall": "nuxt prepare"
  },
  "type": "module",
  "types": "./dist/types.d.ts",
  "version": "1.0.0"
}
