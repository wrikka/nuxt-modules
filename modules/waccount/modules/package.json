{
  "name": "@wrikka/waccount",
  "version": "0.0.1",
  "description": "WAccount authentication module for Nuxt",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/module.d.ts",
      "import": "./dist/module.mjs",
      "require": "./dist/module.cjs"
    },
    "./runtime": {
      "import": "./src/runtime/index.ts",
      "types": "./src/runtime/index.ts"
    },
    "./runtime/*": {
      "import": "./src/runtime/*",
      "types": "./src/runtime/*"
    }
  },
  "main": "./dist/module.cjs",
  "types": "./dist/module.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt-build-module",
    "preview": "nuxi preview playground",
    "format": "dprint fmt",
    "lint": "nuxt typecheck",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "typecheck": "vue-tsc --noEmit",
    "prepare": "nuxt-module-build --prepare",
    "prepublishOnly": "npm run build",
    "release": "release-it"
  },
  "dependencies": {
    "@nuxt/kit": "^4.3.1",
    "@workos-inc/node": "^8.7.0",
    "defu": "^6.1.4",
    "drizzle-orm": "^0.45.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.29",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/test-utils": "^4.0.0",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "nuxt": "^4.3.1"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@latest"
  }
}
