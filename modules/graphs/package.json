{
  "dependencies": {
    "nuxt": "^3.0.0",
    "vue": "^3.0.0"
  },
  "description": "Nuxt graph algorithms and visualization module",
  "devDependencies": {
    "@types/bun": "latest",
    "tsdown": "^0.18.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "@nuxt/devtools": "latest",
    "@nuxt/kit": "latest",
    "vitepress": "^1.0.0",
    "@types/node": "^20.0.0"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./nuxt": "./dist/module.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "nuxt",
    "graphs",
    "algorithms",
    "visualization",
    "typescript",
    "vue"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/module.mjs",
  "name": "@wrikka/graphs",
  "overrides": {
    "vite": "npm:rolldown-vite@latest"
  },
  "private": true,
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt-build-module",
    "lint": "nuxt typecheck",
    "release": "release-it",
    "test": "vitest",
    "postinstall": "nuxt prepare"
  },
  "type": "module",
  "types": "./dist/index.d.mts",
  "version": "0.1.0"
}
