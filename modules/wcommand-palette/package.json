{
  "name": "@wrikka/wcommand-palette",
  "type": "module",
  "version": "0.0.1",
  "main": "./dist/module.mjs",
  "exports": {
    ".": {
      "import": "./dist/module.mjs",
      "require": "./dist/module.mjs"
    },
    "./runtime": {
      "import": "./src/runtime/index.ts",
      "types": "./src/runtime/index.ts"
    },
    "./runtime/*": {
      "import": "./src/runtime/*",
      "types": "./src/runtime/*"
    }
  },
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt-build-module",
    "preview": "nuxt preview",
    "format": "dprint fmt",
    "lint": "nuxt typecheck && oxlint --type-aware --fix",
    "typecheck": "nuxt typecheck",
    "test": "vitest",
    "verify": "bun run lint && bun run test && bun run build",
    "release": "release-it"
  },
  "dependencies": {
    "@nuxt/kit": "^4.3.1",
    "@vueuse/core": "^14.2.1",
    "@vueuse/nuxt": "^14.2.1",
    "defu": "^6.1.4",
    "fuse.js": "^7.1.0",
    "nuxt": "^4.3.1",
    "vue": "^3.5.29"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.3.1",
    "@types/node": "^25.3.2",
    "dprint": "^0.51.1",
    "oxlint": "^1.50.0",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  }
}
