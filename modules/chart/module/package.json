{
	"name": "@wpackages/chart",
	"version": "0.1.0",
	"private": true,
	"description": "Nuxt chart utilities module",
	"type": "module",
	"keywords": [
		"nuxt",
		"chart",
		"visualization",
		"typescript"
	],
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": "./dist/index.mjs",
		"./nuxt": "./dist/module.mjs",
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "nuxt-build-module",
		"dev": "nuxt dev",
		"test": "vitest",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:ui": "vitest --ui",
		"test:watch": "vitest --watch"
	},
	"dependencies": {
		"nuxt": "^4.3.1",
		"vite-plugin-checker": "^0.12.0",
		"vue": "^3.5.29"
	},
	"devDependencies": {
		"@nuxt/devtools": "3.2.2",
		"@nuxt/icon": "^2.2.1",
		"@nuxt/kit": "4.3.1",
		"@nuxt/module-builder": "^1.0.2",
		"@nuxt/schema": "^4.3.1",
		"@types/bun": "1.3.9",
		"@unocss/nuxt": "^66.6.4",
		"@vueuse/core": "^14.2.1",
		"jsdom": "^28.1.0",
		"tsdown": "^0.20.3",
		"typescript": "^5.9.3",
		"unocss": "^66.6.4",
		"vitest": "^4.0.18",
		"vue-tsc": "^3.2.5"
	},
	"module": "./dist/module.mjs"
}
