{
  "name": "@wrikka/wslide",
  "type": "module",
  "version": "0.0.1",
  "main": "./dist/module.mjs",
  "exports": {
    ".": {
      "import": "./dist/module.mjs",
      "require": "./dist/module.mjs"
    },
    "./runtime": {
      "import": "./src/runtime/index.ts",
      "types": "./src/runtime/index.ts"
    },
    "./runtime/*": {
      "import": "./src/runtime/*",
      "types": "./src/runtime/*"
    }
  },
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt-build-module",
    "preview": "nuxt preview",
    "format": "dprint fmt --write",
    "postinstallt": "nuxt prepare",
    "lint": "nuxt typecheck",
    "test": "vitest",
    "verify": "bun run lint && bun run test && bun run build",
    "release": "release-it"
  },
  "dependencies": {
    "@nuxt/kit": "^4.3.1",
    "@vueuse/core": "^14.2.1",
    "@vueuse/nuxt": "^14.2.1",
    "buffer": "^6.0.3",
    "defu": "^6.1.4",
    "gray-matter": "^4.0.3",
    "katex": "^0.16.33",
    "marked": "^17.0.3",
    "mermaid": "^11.12.3",
    "nuxt": "^4.3.1",
    "shiki": "^3.23.0",
    "vue": "^3.5.29"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.3.1",
    "@types/katex": "^0.16.8",
    "@types/mermaid": "^9.2.0",
    "@types/node": "^25.3.2",
    "@unocss/nuxt": "^66.6.2",
    "dprint": "^0.52.0",
    "unocss": "^66.6.2",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@latest"
  }
}
