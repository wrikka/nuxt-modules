{
  "name": "nuxt-mcp-dev",
  "type": "module",
  "version": "0.3.2",
  "description": "MCP server from your Nuxt dev server helping models to understand your Nuxt app better.",
  "license": "MIT",
  "homepage": "https://github.com/antfu/nuxt-mcp-dev#readme",
  "repository": "antfu/nuxt-mcp-dev",
  "bugs": "https://github.com/antfu/nuxt-mcp-dev/issues",
  "keywords": [
    "nuxt",
    "mcp",
    "modelcontextprotocol"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./dist/module.mjs"
  },
  "main": "./dist/module.mjs",
  "module": "./dist/module.mjs",
  "types": "./dist/types.d.mts",
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "nitropack": "^2 || ^3",
    "nuxi": ">=3",
    "nuxt": ">=3.5.0",
    "vite": ">=6"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.1",
    "@nuxt/kit": "^4.2.2",
    "ansis": "^4.2.0",
    "async-cache-dedupe": "^3.4.0",
    "citty": "^0.1.6",
    "debug": "^4.4.3",
    "pathe": "^2.0.3",
    "unimport": "^5.6.0",
    "zod": "^3.25.76",
    "vite-plugin-mcp": "0.3.2"
  },
  "devDependencies": {
    "@nuxt/devtools": "^3.1.1",
    "@nuxt/eslint-config": "^1.12.1",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.2.2",
    "@nuxt/test-utils": "^3.21.0",
    "@types/debug": "^4.1.12",
    "@types/node": "latest",
    "eslint": "^9.39.2",
    "nitropack": "^2.12.9",
    "nuxi": "^3.31.3",
    "nuxt": "^4.2.2",
    "typescript": "~5.9.3",
    "vitest": "^4.0.16",
    "vue-tsc": "^3.2.1"
  },
  "scripts": {
    "build": "nuxt-module-build build",
    "play": "DEBUG=nuxt:mcp:server,vite:mcp:server PORT=4000 nuxi dev playground",
    "play:build": "nuxi build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground"
  }
}