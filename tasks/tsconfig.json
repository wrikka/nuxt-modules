{
	"extends": "./.nuxt/tsconfig.json",
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"forceConsistentCasingInFileNames": true,
		"lib": [
			"ESNext",
			"DOM",
			"DOM.Iterable"
		],
		"types": [
			"node"
		],
		"paths": {
			"~/*": [
				"./*"
			],
			"~~/*": [
				"./*"
			],
			"#shared/*": [
				"./shared/*"
			]
		}
	},
	"include": [
		"./app/**/*",
		"./server/**/*",
		"./shared/**/*",
		"./.nuxt/**/*"
	]
}