{
  "name": "nuxt-modules",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "modules/*",
    "wcomposables"
  ],
  "dependencies": {
    "nuxt": "^4.3.1"
  },
  "devDependencies": {
    "@types/bun": "1.3.9",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "watch": "turbo watch verify",
    "prepare": "bunx lefthook install && bunx taze -r -w -i",
    "dev": "nuxt dev",
    "format": "turbo format",
    "scan": "bunx sg scan -r",
    "check:modules": "bunx node-modules-inspector",
    "lint": "turbo lint",
    "test": "vitest",
    "build": "nuxt-build-module",
    "verify": "turbo lint && turbo test && turbo build",
    "devtools": "turbo devtools",
    "release": "release-it"
  }
}
