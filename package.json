{
  "name": "nuxt-modules",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "modules/*",
    "wcomposables"
  ],
  "scripts": {
    "watch": "turbo watch verify",
    "prepare": "bunx lefthook install && ",
    "dev": "nuxt dev",
    "format": "turbo format",
    "scan": "bunx sg scan -r",
    "check:modules": "bunx node-modules-inspector",
    "lint": "nuxt typecheck && oxlint --type-aware --fix && biome lint --write",
    "test": "vitest",
    "build": "nuxt-build-module",
    "verify": "turbo lint && turbo test && turbo build",
    "devtools": "turbo devtools",
    "release": "release-it"
  }
}
